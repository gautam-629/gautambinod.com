# Database
DATABASE_URL="postgresql://user:password@localhost:5432/devfolio"

# Auth
# ─── REQUIRED — Auth will throw JWTSessionError without this ──────────────────
# Generate a strong secret: openssl rand -base64 32
# Copy the output and paste it below. Do NOT use the placeholder value.
# NEXTAUTH_URL MUST exactly match the URL you access the app from (port included).
NEXTAUTH_SECRET="REPLACE_ME_run_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Your Name <your@email.com>"
ADMIN_EMAIL="admin@yourdomain.com"

# Optional
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
